{
  "version": "6",
  "dialect": "sqlite",
  "tables": {
    "users": {
      "name": "users",
      "columns": {
        "id": { "name": "id", "type": "integer", "primaryKey": true, "notNull": true, "autoIncrement": true },
        "username": { "name": "username", "type": "text", "notNull": true },
        "email": { "name": "email", "type": "text", "notNull": true },
        "password": { "name": "password", "type": "text", "notNull": true },
        "is_admin": { "name": "is_admin", "type": "integer", "notNull": true, "default": 0 },
        "created_at": { "name": "created_at", "type": "integer", "notNull": true }
      },
      "indexes": {
        "users_username_unique": { "name": "users_username_unique", "columns": ["username"], "isUnique": true },
        "users_email_unique": { "name": "users_email_unique", "columns": ["email"], "isUnique": true }
      }
    },
    "sessions": {
      "name": "sessions",
      "columns": {
        "id": { "name": "id", "type": "text", "primaryKey": true, "notNull": true },
        "user_id": { "name": "user_id", "type": "integer", "notNull": true },
        "created_at": { "name": "created_at", "type": "integer", "notNull": true },
        "expires_at": { "name": "expires_at", "type": "integer", "notNull": true }
      },
      "indexes": {
        "sessions_user_id_idx": { "name": "sessions_user_id_idx", "columns": ["user_id"], "isUnique": false },
        "sessions_expires_at_idx": { "name": "sessions_expires_at_idx", "columns": ["expires_at"], "isUnique": false }
      }
    },
    "server_defaults": {
      "name": "server_defaults",
      "columns": {
        "id": { "name": "id", "type": "integer", "primaryKey": true, "notNull": true },
        "memory": { "name": "memory", "type": "integer", "notNull": true, "default": 1024 },
        "swap": { "name": "swap", "type": "integer", "notNull": true, "default": 0 },
        "disk": { "name": "disk", "type": "integer", "notNull": true, "default": 2048 },
        "cpu": { "name": "cpu", "type": "integer", "notNull": true, "default": 100 }
      },
      "indexes": {}
    },
    "economy_settings": {
      "name": "economy_settings",
      "columns": {
        "id": { "name": "id", "type": "integer", "primaryKey": true, "notNull": true },
        "currency_name": { "name": "currency_name", "type": "text", "notNull": true, "default": "TQN" }
      },
      "indexes": {}
    },
    "wallets": {
      "name": "wallets",
      "columns": {
        "user_id": { "name": "user_id", "type": "integer", "primaryKey": true, "notNull": true },
        "balance": { "name": "balance", "type": "integer", "notNull": true, "default": 0 }
      },
      "indexes": {}
    }
  }
}
